# Application
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
APP_ENV=demo

# OpenTelemetry
OTEL_SERVICE_NAME=api
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER=always_on

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_AUTH_ANONYMOUS_ENABLED=false

# Service account token used by Grafana MCP (provisioned automatically)
# Use this value in ~/.cursor/mcp.json GRAFANA_SERVICE_ACCOUNT_TOKEN
GRAFANA_MCP_TOKEN=demo-mcp-token-change-in-prod



# Ports (external) 
# App:        http://localhost:3001
# Grafana:    http://localhost:3000
# Prometheus: http://localhost:9090
# Loki:       http://localhost:3100
# Tempo:      http://localhost:3200
# Alloy UI:   http://localhost:12345

# ─── Grafana MCP (for ~/.cursor/mcp.json reference)
# GRAFANA_URL=http://localhost:3000
# GRAFANA_SERVICE_ACCOUNT_TOKEN=demo-mcp-token-change-in-prod
